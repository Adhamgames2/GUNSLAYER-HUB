local function CreateGunSlayerESP(target, name, color, isPlayer)
    if target:FindFirstChild("GUNSLAYER_ESP") then 
        target.GUNSLAYER_ESP.Frame.TextLabel.TextColor3 = color
        return 
    end
    
    local billboard = Instance.new("BillboardGui", target)
    billboard.Name = "GUNSLAYER_ESP"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 180, 0, 100)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    
    local container = Instance.new("Frame", billboard)
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    
    local nameLabel = Instance.new("TextLabel", container)
    nameLabel.Size = UDim2.new(1, 0, 0.25, 0)
    nameLabel.Text = name
    nameLabel.TextColor3 = color
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextScaled = true
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextStrokeTransparency = 0
    
    if isPlayer then
        local distanceLabel = Instance.new("TextLabel", container)
        distanceLabel.Size = UDim2.new(1, 0, 0.15, 0)
        distanceLabel.Position = UDim2.new(0, 0, 0.25, 0)
        distanceLabel.Text = "📏 --m"
        distanceLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
        distanceLabel.Font = Enum.Font.Gotham
        distanceLabel.TextScaled = true
        distanceLabel.BackgroundTransparency = 1
        distanceLabel.TextStrokeTransparency = 0
        
        local barBg = Instance.new("Frame", container)
        barBg.Size = UDim2.new(0.85, 0, 0.12, 0)
        barBg.Position = UDim2.new(0.075, 0, 0.42, 0)
        barBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        barBg.BorderSizePixel = 0
        local bgCorner = Instance.new("UICorner", barBg)
        bgCorner.CornerRadius = UDim.new(0, 6)
        
        local barFg = Instance.new("Frame", barBg)
        barFg.Size = UDim2.new(1, 0, 1, 0)
        barFg.BackgroundColor3 = Color3.fromRGB(0, 255, 120)
        barFg.BorderSizePixel = 0
        local fgCorner = Instance.new("UICorner", barFg)
        fgCorner.CornerRadius = UDim.new(0, 4)
        
        task.spawn(function()
            while billboard.Parent do
                pcall(function()
                    local char = target.Parent
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    local myHRP = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                    
                    if hum and myHRP then
                        local distance = math.floor((myHRP.Position - target.Position).Magnitude)
                        distanceLabel.Text = "📏 " .. distance .. "m"
                        
                        if distance < 30 then distanceLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                        else distanceLabel.TextColor3 = Color3.fromRGB(255, 255, 0) end
                        
                        local hpRatio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        barFg:TweenSize(UDim2.new(hpRatio, 0, 1, 0), "Out", "Quad", 0.3, true)
                        barFg.BackgroundColor3 = Color3.fromHSV((1 - hpRatio) * 0.33, 1, 1)
                    end
                end)
                task.wait(0.3)
            end
        end)
    end
end

local function UpdatePlayerList()
    local list = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP then
            if Settings.SearchText == "" then table.insert(list, p.Name)
            elseif p.Name:lower():find(Settings.SearchText:lower()) then table.insert(list, p.Name) end
        end
    end
    if #list == 0 then table.insert(list, "لا يوجد لاعبين") end
    return list
end

local function ExecuteTweenSticky(targetName)
    local victim = Players:FindFirstChild(targetName)
    if not victim or not victim.Character or not victim.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local targetHrp = victim.Character.HumanoidRootPart
    local distance = (hrp.Position - targetHrp.Position).Magnitude
    local travelTime = math.max(0.1, distance / Settings.TweenSpeed)
    
    if CurrentTween then CurrentTween:Cancel() end
    Settings.StickyActive = false
    
    CurrentTween = TweenService:Create(
        hrp, 
        TweenInfo.new(travelTime, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), 
        {CFrame = targetHrp.CFrame * CFrame.new(0, Settings.PlayerLiftHeight, 4)}
    )
    CurrentTween:Play()
    CurrentTween.Completed:Connect(function()
        if Settings.TweenStickyToggle then Settings.StickyActive = true end
    end)
end

