-- [ 7. المحركات والخوارزميات (The Loops) ]

task.spawn(function()
    while task.wait(1) do
        pcall(function()
            if Settings.RadarEnabled then
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local hrp = p.Character.HumanoidRootPart
                        local hum = p.Character:FindFirstChildOfClass("Humanoid")
                        local currentPos = hrp.Position
                        
                        if hum and hum.Health > 0 and not DetectedHackers[p.Name] then
                            local isHacking = false
                            local hackType = ""
                            
                            if LastPositions[p.Name] then
                                local distanceMoved = (currentPos - LastPositions[p.Name]).Magnitude
                                if distanceMoved > 80 and distanceMoved < 400 then 
                                    isHacking = true
                                    hackType = "🚀 سرعة عالية / طيران"
                                end
                            end
                            LastPositions[p.Name] = currentPos
                            
                            if hrp.RotVelocity.Magnitude > 60 then
                                isHacking = true
                                hackType = "🌪️ Spinbot"
                            end
                            
                            if isHacking then
                                DetectedHackers[p.Name] = true
                                Rayfield:Notify({Title = "🚨 رادار الهكرات!", Content = "اللاعب [" .. p.Name .. "] بيستخدم: " .. hackType, Duration = 8})
                            end
                        end
                    end
                end
            end
        end)
    end
end)

